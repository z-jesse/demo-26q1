{
  "generated_at": "May 20, 2026",
  "csv_report": {
    "title": "Membership vs Classes (Apr 20, 2026 \u2013 May 20, 2026)",
    "sql": "SELECT\n  vm.plan_name AS membership_plan,\n  va.class_name,\n  va.instructor_name,\n  COUNT(*) AS total_bookings,\n  SUM(CASE WHEN va.status = 'confirmed' AND va.checked_in_at IS NOT NULL THEN 1 ELSE 0 END) AS attended,\n  SUM(CASE WHEN va.status = 'cancelled' THEN 1 ELSE 0 END) AS cancelled,\n  SUM(CASE WHEN va.status = 'waitlisted' THEN 1 ELSE 0 END) AS waitlisted,\n  SUM(CASE WHEN va.status = 'confirmed' AND va.checked_in_at IS NULL THEN 1 ELSE 0 END) AS confirmed_no_checkin,\n  ROUND(\n    100.0 * SUM(CASE WHEN va.status = 'confirmed' AND va.checked_in_at IS NOT NULL THEN 1 ELSE 0 END)\n    / NULLIF(COUNT(*), 0), 1\n  ) AS attendance_rate_pct\nFROM vw_class_attendance va\nJOIN vw_memberships vm\n  ON va.customer_id = vm.customer_id\nWHERE\n  strftime('%Y-%m-%d', va.start_at) >= '2026-04-20'\n  AND strftime('%Y-%m-%d', va.start_at) <= '2026-05-20'\n  AND vm.state = 'active'\nGROUP BY\n  vm.plan_name,\n  va.class_name,\n  va.instructor_name\nORDER BY\n  vm.plan_name ASC,\n  attended DESC,\n  va.class_name ASC",
